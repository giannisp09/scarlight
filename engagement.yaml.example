# Scarlight engagement scope — authorization configuration.
#
# Copy this file to one of:
#   1. ~/.scarlight/engagement.yaml         (default for single-engagement use)
#   2. ./engagement.yaml                    (per-working-dir engagement)
#   3. Anywhere; point SCARLIGHT_ENGAGEMENT=/abs/path at it
#
# Scarlight refuses to start a turn without a valid scope on file.
# See CODE_OF_USE.md for the operator policy this file binds you to.
#
# Internal harnesses and the test suite set SCARLIGHT_NO_ENGAGEMENT=1
# to bypass this guard with a warning. DO NOT set that in production.

# Unique identifier for the engagement. Use whatever convention is
# meaningful to you (project code, contract reference, CTF event slug).
engagement_id: "example-pentest-2026-q2"

# Human-readable authorization reference. The point of this field is
# auditability: a reviewer reading this file should be able to trace
# the operator's authority back to a concrete document or program.
authorization_reference: >
  Master Services Agreement 2026-04 with Acme Corp,
  Statement of Work dated 2026-05-01 (Appendix B: external web-app pentest),
  point of contact: security@acme.example

# Operator acknowledgment of CODE_OF_USE.md. acknowledged MUST be the
# literal YAML boolean `true`. The operator and date fields are required
# so the file documents who is accountable for this engagement and when
# they took it on. code_of_use_version is optional but recommended.
operator_acknowledgment:
  acknowledged: true
  operator: "Operator Name <operator@example.com>"
  date: "2026-05-18"
  code_of_use_version: "1"

# Authorized targets — hostnames, IPs, CIDR ranges, or URLs you have
# permission to test. The list MUST be non-empty. Be specific. The guard
# does not currently enforce per-target authorization on individual tool
# calls (that is a planned follow-up); for v1 this list is documentation
# of the operator's declared scope.
targets:
  - "acme-webapp.example.com"
  - "api.acme-webapp.example.com"
  - "10.10.10.0/24"

# Optional engagement window. If start is set and in the future, or end
# is set and in the past, the guard refuses to start (the engagement is
# either not yet authorized or has expired). ISO-8601 datetimes; the
# trailing 'Z' shorthand for UTC is accepted.
window:
  start: "2026-05-18T00:00:00Z"
  end:   "2026-06-30T23:59:59Z"

# Free-form notes for the operator's own records. Not interpreted by the
# guard, surfaced in scope summaries.
notes: |
  External web-app pentest + internal /24 authorized by SoW Appendix B.
  Out-of-band notifications: security@acme.example.
  All findings to be reported via the Acme private bug-bounty channel.
